// Test arrow functions

const arr = [1, 2, 3];
const filtered = arr.filter(x => x > 1);
const mapped = arr.map((x, i) => x * 2);

// Arrow function with block body
const process = (item) => {
  console.log(item);
  return item * 2;
};

// Type annotations
const typed: (x: number) => number = x => x * 2;