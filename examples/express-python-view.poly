import express
import json

def py_view(path):
  return json.dumps({
    "framework": "express",
    "runtime": "python",
    "path": path
  })

const app = express()
const express_view = (req, res) => {
  const payload = JSON.parse(py_view(req.path))
  res.status(200).json(payload)
}
const res = {
  "statusCode": 0,
  "body": "",
  "status": (code) => {
    res.statusCode = code
    return res
  },
  "json": (payload) => {
    res.body = JSON.stringify(payload)
    return res
  }
}

app.get("/poly/express", express_view)
express_view({"path": "/poly/express"}, res)
console.log(res.statusCode)
console.log(res.body)
