// Cursed Concurrency Blender
// Python generators → Go channels → JS transforms → all talking to each other.

import os

// [go] buffered channels
const inbox = make(16)
const outbox = make(16)

// [python] generator yields file metadata dicts
def crawl(root):
  for entry in os.scandir(root):
    yield {"name": entry["name"], "size": os.path.getsize(entry["path"])}

// [js] transformer — arrows below force JS while reading from Go channels
function process(item) {
  return {
    "name": item.name,
    "size": item.size,
    "label": `${item.name}:${item.size}`
  }
}

// [go] worker function: compileable as an OmniVM plugin; channel ops below
// still exercise manifest-level send/close behavior across runtimes.
func worker(id) {
  return id
}

// [go] spin up the swarm
go worker(1)
go worker(2)
go worker(3)
go worker(4)

// [python] drain generator into go channel
for item in crawl("/var/data"):
  inbox <- item
close(inbox)

// [js] drain the Go channel into JS, transform the Python payloads
const raw = Array.from(inbox).map(item => process(item))

// [go] publish transformed rows back through another Go channel
for result in raw:
  outbox <- result
close(outbox)

// [js] arrows yank the channel results back to JS land
const rows = Array.from(outbox).map(r => r)
const names = rows.map(r => r.name.toUpperCase())
const deduped = names.filter((n, i) => names.indexOf(n) === i)

// [python] python takes over for the final analysis
const ranked = sorted(deduped)
const total = len(ranked)
const report = ranked

// [go] publish the final result on a done channel
const done = make(1)
done <- report
close(done)

print(f"Processed {total} items across 3 runtimes")
