// Cursed Concurrency Blender
// Python generators → Go channels → JS async → all talking to each other.

import os
import json

// [go] buffered channels
const inbox = make(16)
const outbox = make(16)

// [python] generator yields file metadata dicts
def crawl(root):
  for entry in os.scandir(root):
    yield {"name": entry.name, "size": os.path.getsize(entry.path)}

// [js] async transformer — arrows force JS even though it reads from Go channels
async function process(item) {
  const enriched = await fetch(`/api/enrich?name=${item.name}`)
  const payload = await enriched.json()
  return payload
}

// [go] fanout workers: recv from channel, process, send result
func worker(id) {
  job := <-inbox
  result := process(job)
  outbox <- result
}

// [go] spin up the swarm
go worker(1)
go worker(2)
go worker(3)
go worker(4)

// [python] drain generator into go channel
for item in crawl("/var/data"):
  inbox <- item
close(inbox)

// [js] arrows yank the results back to JS land
const raw = Array.from(outbox)
const names = raw.map(r => r.name.toUpperCase())
const deduped = names.filter((n, i) => names.indexOf(n) === i)

// [python] python takes over for the final analysis
const ranked = sorted(deduped)
const total = len(ranked)
const report = json.dumps(ranked)

// [go] publish the final result on a done channel
const done = make(0)
done <- report
close(done)

print(f"Processed {total} items across 3 runtimes")
