// Cursed Concurrency Blender
// Python generators → Go channels → JS transforms → all talking to each other.

import os

// [go] buffered channels
const inbox = make(16)
const outbox = make(16)

// [python] generator yields file metadata dicts
def crawl(root):
  for entry in os.scandir(root):
    yield {"name": entry["name"], "size": os.path.getsize(entry["path"])}

// [js] transformer — arrows below force JS while reading from a Go channel
function process(item) {
  return {
    "name": item.name,
    "size": item.size,
    "label": `${item.name}:${item.size}`
  }
}

// [go] worker function: compiled as an OmniVM plugin and connected to
// manifest channels through Go helper functions.
func worker(id) {
  while true {
    item := recv("inbox")
    if item == nil {
      return id
    }
    send("outbox", item)
  }
  return id
}

// [go] spin up the swarm
const w1 = go worker(1)
const w2 = go worker(2)
const w3 = go worker(3)
const w4 = go worker(4)

// [python] drain generator into go channel
for item in crawl("/var/data"):
  inbox <- item
close(inbox)

// [go] join the workers before closing their output channel
const joined = wait(w1, w2, w3, w4)
const worker_count = len(joined)
close(outbox)

// [js] Array.from consumes the Go channel's JS iterable adapter
const rows = Array.from(outbox).map(r => r)
const raw = rows.map(item => process(item))
const names = raw.map(r => r.name.toUpperCase())
const deduped = names.filter((n, i) => names.indexOf(n) === i)

// [python] python takes over for the final analysis
const ranked = sorted(deduped)
const total = len(ranked)
const report = ranked

// [go] publish the final result on a done channel
const done = make(1)
done <- report
close(done)
const final_report = list(done)
const delivered = len(final_report)

print(f"Processed {total} items across 3 runtimes; workers {worker_count}; delivered {delivered} report")
