import jinja2
import marked from "marked"

func content_key(slug) {
  return slug
}

markdown_source = jinja2.Template("# Poly Docs\n\nThis page is rendered through multiple runtimes.").render()
const html = marked.parse(markdown_source)
const key = content_key("poly-docs")

print(f"Jinja2/Marked/Go docs key={key} length={len(html)}")
