// Subset of parser code in PolyScript syntax

class Parser {
  constructor(tokens) {
    this.tokens = tokens;
    this.current = 0;
    this.errors = [];
    this.braceDepth = 0;
  }
  
  getErrors() {
    return this.errors;
  }
  
  parse() {
    const body = [];
    let iterations = 0;
    const maxIterations = 1000;
    
    while (!this.isAtEnd()) {
      iterations++;
      if (iterations > maxIterations) {
        console.error("Parser exceeded maximum iterations");
        break;
      }
      
      const item = this.parseTopLevel();
      if (item) {
        body.push(item);
      }
    }
    
    return {
      kind: "Program",
      body: body,
      span: this.createSpan(0, this.current)
    };
  }
  
  isAtEnd() {
    return this.current >= this.tokens.length;
  }
  
  peek() {
    if (this.isAtEnd()) {
      return null;
    }
    return this.tokens[this.current];
  }
  
  advance() {
    if (!this.isAtEnd()) {
      this.current++;
    }
    return this.previous();
  }
  
  previous() {
    if (this.current > 0) {
      return this.tokens[this.current - 1];
    }
    return null;
  }
  
  check(type) {
    const token = this.peek();
    return token && token.type === type;
  }
  
  consume(type, message) {
    if (this.check(type)) {
      return this.advance();
    }
    throw new Error(message);
  }
  
  parseTopLevel() {
    // Skip semicolons and newlines
    while (this.check(";") || this.check("NEWLINE")) {
      this.advance();
    }
    
    if (this.isAtEnd()) {
      return null;
    }
    
    // Try to parse declaration or statement
    const token = this.peek();
    
    switch (token.type) {
      case "function":
        return this.parseFunctionDecl();
      case "class":
        return this.parseClassDecl();
      case "const":
        return this.parseConstDecl();
      case "let":
        return this.parseVarDecl();
      case "if":
        return this.parseIfStatement();
      case "for":
        return this.parseForStatement();
      case "while":
        return this.parseWhileStatement();
      case "return":
        return this.parseReturnStatement();
      default:
        return this.parseExprStatement();
    }
  }
  
  parseFunctionDecl() {
    this.consume("function", "Expected 'function'");
    const name = this.parseIdentifier();
    
    this.consume("(", "Expected '(' after function name");
    const params = [];
    
    while (!this.check(")") && !this.isAtEnd()) {
      if (params.length > 0) {
        this.consume(",", "Expected ',' between parameters");
      }
      params.push(this.parseParam());
    }
    
    this.consume(")", "Expected ')' after parameters");
    const body = this.parseBlock();
    
    return {
      kind: "FuncDecl",
      name: name,
      params: params,
      body: body,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseClassDecl() {
    this.consume("class", "Expected 'class'");
    const name = this.parseIdentifier();
    
    this.consume("{", "Expected '{' after class name");
    const members = [];
    
    while (!this.check("}") && !this.isAtEnd()) {
      members.push(this.parseClassMember());
    }
    
    this.consume("}", "Expected '}' after class members");
    
    return {
      kind: "ClassDecl",
      name: name,
      members: members,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseIfStatement() {
    this.consume("if", "Expected 'if'");
    this.consume("(", "Expected '(' after 'if'");
    const test = this.parseExpression();
    this.consume(")", "Expected ')' after condition");
    const consequent = this.parseBlock();
    
    let alternate = null;
    if (this.check("else")) {
      this.advance();
      if (this.check("if")) {
        alternate = this.parseIfStatement();
      } else {
        alternate = this.parseBlock();
      }
    }
    
    return {
      kind: "If",
      arms: [{
        test: test,
        body: consequent,
        span: this.createSpan(0, this.current)
      }],
      elseBody: alternate,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseExpression() {
    return this.parseBinary();
  }
  
  parseBinary() {
    let left = this.parsePrimary();
    
    while (this.checkBinaryOp()) {
      const op = this.advance().value;
      const right = this.parsePrimary();
      left = {
        kind: "Binary",
        op: op,
        left: left,
        right: right,
        span: this.createSpan(0, this.current)
      };
    }
    
    return left;
  }
  
  parsePrimary() {
    const token = this.peek();
    
    if (!token) {
      throw new Error("Unexpected end of input");
    }
    
    switch (token.type) {
      case "NUMBER":
        this.advance();
        return {
          kind: "NumericLiteral",
          raw: token.value,
          base: "decimal",
          span: this.createSpan(0, this.current)
        };
        
      case "STRING":
        this.advance();
        return {
          kind: "StringLiteral",
          parts: [{
            kind: "Text",
            value: token.value
          }],
          flags: {},
          delimiter: '"',
          span: this.createSpan(0, this.current)
        };
        
      case "true":
      case "false":
        this.advance();
        return {
          kind: "BooleanLiteral",
          value: token.value === "true",
          span: this.createSpan(0, this.current)
        };
        
      case "null":
        this.advance();
        return {
          kind: "NullLiteral",
          span: this.createSpan(0, this.current)
        };
        
      case "IDENTIFIER":
        return this.parseIdentifier();
        
      case "(":
        this.advance();
        const expr = this.parseExpression();
        this.consume(")", "Expected ')' after expression");
        return expr;
        
      case "[":
        return this.parseArrayLiteral();
        
      case "{":
        return this.parseObjectLiteral();
        
      default:
        throw new Error("Unexpected token: " + token.value);
    }
  }
  
  parseIdentifier() {
    const token = this.consume("IDENTIFIER", "Expected identifier");
    return {
      kind: "Identifier",
      name: token.value,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseBlock() {
    this.consume("{", "Expected '{'");
    const statements = [];
    
    while (!this.check("}") && !this.isAtEnd()) {
      const stmt = this.parseStatement();
      if (stmt) {
        statements.push(stmt);
      }
    }
    
    this.consume("}", "Expected '}'");
    
    return {
      kind: "Block",
      statements: statements,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseStatement() {
    // Skip semicolons
    while (this.check(";")) {
      this.advance();
    }
    
    if (this.isAtEnd() || this.check("}")) {
      return null;
    }
    
    return this.parseTopLevel();
  }
  
  parseParam() {
    const name = this.parseIdentifier();
    return {
      name: name,
      span: this.createSpan(0, this.current)
    };
  }
  
  parseClassMember() {
    if (this.check("constructor")) {
      return this.parseConstructor();
    }
    
    const name = this.parseIdentifier();
    
    if (this.check("(")) {
      // Method
      this.advance();
      const params = [];
      
      while (!this.check(")") && !this.isAtEnd()) {
        if (params.length > 0) {
          this.consume(",", "Expected ','");
        }
        params.push(this.parseParam());
      }
      
      this.consume(")", "Expected ')'");
      const body = this.parseBlock();
      
      return {
        kind: "Method",
        name: name,
        params: params,
        body: body,
        span: this.createSpan(0, this.current)
      };
    } else {
      // Field
      this.consume(";", "Expected ';' after field");
      return {
        kind: "Field",
        name: name,
        span: this.createSpan(0, this.current)
      };
    }
  }
  
  parseConstructor() {
    this.consume("constructor", "Expected 'constructor'");
    this.consume("(", "Expected '('");
    
    const params = [];
    while (!this.check(")") && !this.isAtEnd()) {
      if (params.length > 0) {
        this.consume(",", "Expected ','");
      }
      params.push(this.parseParam());
    }
    
    this.consume(")", "Expected ')'");
    const body = this.parseBlock();
    
    return {
      kind: "Constructor",
      params: params,
      body: body,
      span: this.createSpan(0, this.current)
    };
  }
  
  checkBinaryOp() {
    const token = this.peek();
    if (!token) return false;
    
    const ops = ["+", "-", "*", "/", "%", "==", "!=", "<", ">", "<=", ">=", "&&", "||"];
    return ops.includes(token.value);
  }
  
  createSpan(start, end) {
    return {
      start: start,
      end: end,
      line: 0,
      column: 0
    };
  }
}