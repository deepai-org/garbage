// Test PolyScript file

function greet(name: string): string {
  return `Hello, ${name}!`;
}

class Person {
  name: string;
  age: number;
  
  constructor(name: string, age: number) {
    this.name = name;
    this.age = age;
  }
  
  greet() {
    console.log(`Hi, I'm ${this.name} and I'm ${this.age} years old`);
  }
}

const person = new Person("Alice", 30);
person.greet();

